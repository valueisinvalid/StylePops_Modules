{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StylePops Garment",
  "description": "Bootstrap ve envanter giysi kaydı — İP-1 veri işleme mimarisi girdisi",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "subcategory",
    "description",
    "fabric_composition",
    "coverage_ratio",
    "color_lab",
    "season_primary",
    "season_usable",
    "thermal_category"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(G|LV|FP)[0-9]{3,}$",
      "description": "Benzersiz parça kimliği — G### sentetik bootstrap, LV### Livostyle görsel envanter"
    },
    "name": {
      "type": "string",
      "description": "Kullanıcıya gösterilen parça adı"
    },
    "category": {
      "type": "string",
      "enum": ["top", "bottom", "outer", "dress", "footwear", "accessory"]
    },
    "subcategory": {
      "type": "string",
      "description": "tshirt, jeans, coat vb."
    },
    "description": {
      "type": "string",
      "description": "Sentence-BERT girdisi — stil ve anlam vektörü için"
    },
    "fabric_composition": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["material", "pct"],
        "properties": {
          "material": { "type": "string" },
          "pct": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "layers": {
      "type": "array",
      "description": "Çok katmanlı giysiler için shell/lining ayrımı",
      "items": {
        "type": "object",
        "required": ["role", "weight", "fabric_composition"],
        "properties": {
          "role": { "type": "string", "enum": ["shell", "lining", "fill"] },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "fabric_composition": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["material", "pct"],
              "properties": {
                "material": { "type": "string" },
                "pct": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "sleeve": {
      "type": ["string", "null"],
      "enum": ["sleeveless", "short", "three_quarter", "long", null]
    },
    "coverage_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Vücut kaplama oranı — efektif_Clo hesabında çarpan"
    },
    "color_lab": {
      "type": "object",
      "required": ["L", "a", "b"],
      "properties": {
        "L": { "type": "number", "minimum": 0, "maximum": 100 },
        "a": { "type": "number" },
        "b": { "type": "number" }
      }
    },
    "season_primary": {
      "type": "string",
      "enum": ["kis", "sonbahar", "ilkbahar", "yaz"]
    },
    "season_usable": {
      "type": "array",
      "items": { "type": "string", "enum": ["kis", "sonbahar", "ilkbahar", "yaz"] },
      "minItems": 1
    },
    "thermal_category": {
      "type": "string",
      "description": "Risk 2 B Planı kategori lookup anahtarı"
    },
    "layer_role": {
      "type": "string",
      "enum": ["base", "mid", "outer", "bottom", "dress", "footwear", "accessory"],
      "description": "Katman slotu — base+mid+outer üst üste giyilebilir"
    },
    "image_path": {
      "type": "string",
      "description": "Yerel görsel yolu — data/assets/garments/LV001.jpg"
    },
    "image_source_url": {
      "type": "string",
      "description": "Orijinal CDN / kaynak URL (referans)"
    },
    "source": {
      "type": "string",
      "description": "Veri kaynağı: bootstrap_synthetic | livostyle_mit"
    },
    "source_id": {
      "type": "string",
      "description": "Kaynak sistemdeki ürün kimliği (handle veya shopify id)"
    },
    "license": {
      "type": "string",
      "description": "Görsel/metadata lisansı — örn. MIT"
    },
    "snapshot_date": {
      "type": "string",
      "description": "Görsel mirror tarihi ISO-8601"
    }
  }
}
